# Copy this file to supabase/local.env when serving Edge Functions manually.
# Do not commit supabase/local.env.
#
# Usually `supabase start` injects these values for the local stack. Keep this
# file for explicit `supabase functions serve --env-file supabase/local.env`.

SUPABASE_URL=http://127.0.0.1:54321

# Fill from `supabase status` after local Supabase starts.
SUPABASE_ANON_KEY=PASTE_LOCAL_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=PASTE_LOCAL_SERVICE_ROLE_KEY_HERE

# Optional. Supabase Studio references this only for Studio AI features.
OPENAI_API_KEY=
